# AcademiaSync Environment Variables
# Copy to .env and fill in your values

# ── App ──────────────────────────────────────────────────────────────────────
DEBUG=false
SECRET_KEY=your-super-secret-key-change-me-in-production

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (development)
DATABASE_URL=sqlite+aiosqlite:///./academia_sync.db

# PostgreSQL (production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/academia_sync

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=another-secret-key-for-jwt-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── AI Provider ──────────────────────────────────────────────────────────────
# Choose: openai | anthropic |
LLM_PROVIDER="groq"
GROQ_API_KEY="gsk_your_groq_api_key"
LLM_MODEL="llama-3.1-8b-instant"


# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-opus-4-6

# Ollama (local, free)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# LLM_MODEL=llama3

# ── Embeddings ────────────────────────────────────────────────────────────────
# Local (free, no API key needed)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Vector Store ──────────────────────────────────────────────────────────────
VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_DIR=./vector_store/chroma

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
